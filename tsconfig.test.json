{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "types": [
      "vite/client",
      "jest",
      "node",
      "@testing-library/jest-dom"
    ],
    "noEmit": true,
    "verbatimModuleSyntax": false
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "test/**/*.ts",
    "jest.config.ts"
  ]
}